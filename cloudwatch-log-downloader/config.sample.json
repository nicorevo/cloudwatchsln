{
  "environment": "uat",
  "aws": {
    "region": "eu-central-1",
    "profile": "YOUR_AWS_SSO_PROFILE",
    "credentialRefreshIntervalMinutes": 55,
    "loginOnStartupIfNeeded": false,
    "ssoSessionWarningMinutes": 30
  },
  "monitor": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 3847,
    "contextLinesBefore": 10,
    "contextLinesAfter": 10,
    "treeRefreshSeconds": 30,
    "maxExceptionFiles": 50
  },
  "cloudwatch": [
    {
      "project": "download-mail",
      "logGroups": [
        "/eks/my-namespace/my-email-worker-prod",
        "/eks/my-namespace/my-email-services-prod"
      ],
      "filterPattern": "",
      "maxResults": 100000,
      "monitorPatterns": [],
      "exceptionPatterns": [
        "[ERROR][MY-EMAIL-WORKER]",
        " ERROR ",
        "Error on main",
        "Main Error",
        "Traceback (most recent call last)"
      ],
      "schedule": {
        "downloadInterval": "*/1 * * * *",
        "cleanupInterval": "*/60 * * * *"
      },
      "files": {
        "logDirectory": "./logs",
        "retentionMinutes": 60,
        "filePrefix": "download-mail-logs-prod",
        "preserveExceptionPairs": true
      },
      "logging": {
        "level": "info",
        "enableConsole": true
      }
    },
    {
      "project": "os-sinistri",
      "logGroups": [
        "/eks/my-namespace/my-sinistri-worker-prod",
        "/eks/my-namespace/my-sinistri-api-prod"
      ],
      "filterPattern": "",
      "maxResults": 100000,
      "monitorPatterns": [],
      "exceptionPatterns": [
        "[ERROR][MY-SINISTRI]",
        " ERROR ",
        "Error on main",
        "Main Error",
        "Traceback (most recent call last)"
      ],
      "schedule": {
        "downloadInterval": "*/1 * * * *",
        "cleanupInterval": "*/60 * * * *"
      },
      "files": {
        "logDirectory": "./logs",
        "retentionMinutes": 60,
        "filePrefix": "os-sinistri-logs-prod",
        "preserveExceptionPairs": true
      },
      "logging": {
        "level": "info",
        "enableConsole": true
      }
    }
  ]
}
